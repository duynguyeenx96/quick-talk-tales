# ── Server ────────────────────────────────────────────────────
PORT=5001
HOST=0.0.0.0
DEBUG=false

# ── Groq LLM (Story Evaluation) ───────────────────────────────
# Get your API key at: https://console.groq.com
GROQ_API_KEY=${your_groq_api_key}

# ── Whisper (Speech-to-Text) ──────────────────────────────────
# Models: tiny | base | small | medium | large | turbo
# Recommended: base (dev), turbo (prod)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en

# ── Audio Processing ──────────────────────────────────────────
MAX_AUDIO_SIZE=26214400
SUPPORTED_FORMATS=["mp3", "wav", "m4a", "ogg", "webm"]

# ── Performance ───────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=300

# ── Cache ─────────────────────────────────────────────────────
CACHE_TTL=3600

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
