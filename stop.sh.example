#!/bin/bash

# ============================================================
# Quick Talk Tales - Stop Script
#
# SETUP:
#   cp stop.sh.example stop.sh
#   chmod +x stop.sh && ./stop.sh
# ============================================================

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
LOGS_DIR="$ROOT_DIR/.logs"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log()  { echo -e "${GREEN}[✓]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }

stop_service() {
  local name=$1
  local pidfile="$LOGS_DIR/$2.pid"

  if [ -f "$pidfile" ]; then
    local pid
    pid=$(cat "$pidfile")
    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null
      log "Stopped $name (PID: $pid)"
    else
      warn "$name not running (PID: $pid)"
    fi
    rm -f "$pidfile"
  else
    # Fallback: kill by port
    case $2 in
      nestjs) lsof -ti:3000 | xargs kill -9 2>/dev/null && log "Stopped $name (port 3000)" || warn "$name not found" ;;
      fastapi) lsof -ti:5001 | xargs kill -9 2>/dev/null && log "Stopped $name (port 5001)" || warn "$name not found" ;;
      admin)  lsof -ti:5173 | xargs kill -9 2>/dev/null && log "Stopped $name (port 5173)" || warn "$name not found" ;;
    esac
  fi
}

echo ""
echo -e "${CYAN}Stopping Quick Talk Tales services...${NC}"
echo ""

stop_service "NestJS"           nestjs
stop_service "FastAPI AI"       fastapi
stop_service "Admin Dashboard"  admin

echo ""
echo -e "${GREEN}All services stopped.${NC}"
echo ""
